{
  "name": "rspress-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rspress build && node scripts/generate-sitemap.mjs",
    "dev": "rspress dev --host",
    "preview": "rspress preview",
    "deploy": "wrangler deploy",
    "dev:worker": "wrangler dev",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@rspress/core": "^2.0.17"
  },
  "devDependencies": {
    "@types/node": "~26.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.56.0",
    "rsbuild-plugin-google-analytics": "^1.0.6",
    "wrangler": "^4.110.0"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
